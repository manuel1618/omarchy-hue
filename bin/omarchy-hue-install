#!/bin/bash
# Omarchy-Hue Installation Script
# Installs scripts to omarchy bins and patches omarchy-theme-set

set -e

# Get script directory and repo root
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# Installation paths
OMARCHY_BIN_DIR="$HOME/.local/share/omarchy/bin"
THEME_SET_SCRIPT="$OMARCHY_BIN_DIR/omarchy-theme-set"
CONFIG_INSTALL_DIR="$HOME/.config/omarchy/omarchy-hue"

source "$REPO_ROOT/lib/patch-theme.sh"

echo "=== Omarchy-Hue Installer ==="
echo

# Check if we're in the omarchy-hue repo
if [[ ! -d "$REPO_ROOT/lib" ]] || [[ ! -d "$REPO_ROOT/bin" ]]; then
    echo "Error: This script must be run from the omarchy-hue repository"
    exit 1
fi

# Check if omarchy is installed
if [[ ! -d "$OMARCHY_BIN_DIR" ]]; then
    echo "Error: Omarchy bin directory not found at: $OMARCHY_BIN_DIR"
    echo "Please install Omarchy first"
    exit 1
fi

# Check dependencies
echo "Checking dependencies..."
missing=()
command -v jq &>/dev/null || missing+=("jq")
command -v curl &>/dev/null || missing+=("curl")
command -v notify-send &>/dev/null || missing+=("notify-send")

if [[ ${#missing[@]} -gt 0 ]]; then
    echo "Error: Missing required dependencies: ${missing[*]}"
    echo "Install with: sudo pacman -S ${missing[*]}"
    exit 1
fi
echo "✓ All dependencies found"
echo

# Copy scripts to omarchy bin directory
echo "Installing scripts to $OMARCHY_BIN_DIR..."
cp "$REPO_ROOT/bin/omarchy-hue-sync" "$OMARCHY_BIN_DIR/"
cp "$REPO_ROOT/bin/omarchy-hue-setup" "$OMARCHY_BIN_DIR/"
cp "$REPO_ROOT/bin/omarchy-hue-reset" "$OMARCHY_BIN_DIR/"
cp "$REPO_ROOT/bin/omarchy-hue-uninstall" "$OMARCHY_BIN_DIR/"
chmod +x "$OMARCHY_BIN_DIR/omarchy-hue-sync"
chmod +x "$OMARCHY_BIN_DIR/omarchy-hue-setup"
chmod +x "$OMARCHY_BIN_DIR/omarchy-hue-reset"
chmod +x "$OMARCHY_BIN_DIR/omarchy-hue-uninstall"
echo "✓ Scripts installed"
echo

# Copy lib directory to config location (for sourcing by installed scripts)
echo "Installing libraries to $CONFIG_INSTALL_DIR..."
mkdir -p "$CONFIG_INSTALL_DIR"
cp -r "$REPO_ROOT/lib" "$CONFIG_INSTALL_DIR/"

# Preserve existing config if any
if [[ -d "$REPO_ROOT/.config" ]] && [[ "$(ls -A "$REPO_ROOT/.config" 2>/dev/null)" ]]; then
    echo "Copying configuration files..."
    cp -r "$REPO_ROOT/.config" "$CONFIG_INSTALL_DIR/"
    echo "✓ Configuration copied"
else
    # Check if config exists in installed location from previous run
    if [[ ! -f "$CONFIG_INSTALL_DIR/.config/hue-credentials.json" ]]; then
        echo "Warning: No configuration found."
        echo "Run 'omarchy-hue-setup' after installation to configure."
    fi
fi

echo "✓ Libraries and config installed"
echo

# Patch omarchy-theme-set
echo "Patching omarchy-theme-set..."
patch_set_theme || true
echo

# Summary
echo "=== Installation Complete ==="
echo "✓ Installed to: $OMARCHY_BIN_DIR"
echo "✓ Libraries at: $CONFIG_INSTALL_DIR"
echo

# Check if config exists
if [[ -f "$CONFIG_INSTALL_DIR/.config/hue-credentials.json" ]]; then
    echo "✓ Configuration found - you're ready to go!"
    echo
    echo "Test it: omarchy-theme-set catppuccin"
else
    echo "Next step: Run setup to configure your Hue bridge:"
    echo "  omarchy-hue-setup"
fi

echo
echo "Commands available:"
echo "  omarchy-hue-setup    - Interactive setup (bridge, room, brightness, mode)"
echo "  omarchy-hue-sync     - Manual sync current theme to lights"
echo "  omarchy-hue-reset   - Reset lights to white"
echo "  omarchy-hue-uninstall - Remove installation"
echo
echo "View logs: journalctl -t omarchy-hue -f"
echo "To uninstall: omarchy-hue-uninstall"
