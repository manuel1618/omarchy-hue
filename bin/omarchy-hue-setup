#!/bin/bash
# Omarchy-Hue Interactive Setup TUI
# Discover bridge, authenticate, select room, configure brightness

# Force C locale for consistent decimal formatting
export LC_NUMERIC=C

# Get script directory and repo root
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# Source libraries
source "$REPO_ROOT/lib/config.sh" 2>/dev/null || {
    REPO_ROOT="$HOME/.config/omarchy/omarchy-hue"
    source "$REPO_ROOT/lib/config.sh" 2>/dev/null || exit 1
}
source "$REPO_ROOT/lib/hue-api.sh"
source "$REPO_ROOT/lib/colors.sh"

# Global state
BRIDGE_IP=""
USERNAME=""
ROOM_ID=""
ROOM_NAME=""
BRIGHTNESS=""
MODE=""

# ============================================================================
# UI Functions
# ============================================================================

clear_screen() {
    clear
}

print_header() {
    echo "============================================================"
    echo "       Omarchy-Hue Theme Synchronization Setup"
    echo "============================================================"
    echo
}

print_status() {
    echo "Current Status:"
    echo "------------------------------------------------------------"
    
    if [[ -n "$BRIDGE_IP" ]]; then
        echo "  Bridge: $BRIDGE_IP"
        if [[ -n "$USERNAME" ]]; then
            echo "  Connected: Yes"
        else
            echo "  Connected: No"
        fi
    else
        echo "  Bridge: Not connected"
    fi
    
    local theme
    theme=$(colors_get_current_theme 2>/dev/null || echo "Unknown")
    echo "  Theme: $theme"
    
    if [[ -n "$ROOM_NAME" ]]; then
        echo "  Room: $ROOM_NAME"
    else
        echo "  Room: Not selected"
    fi
    
    echo "  Brightness: ${BRIGHTNESS}% (±$(config_get_variation)%)"
    echo "  Mode: $MODE"
    echo "------------------------------------------------------------"
    echo
}

show_menu() {
    # Print menu to stderr so it's not captured by command substitution
    echo "Options:" >&2
    echo "  1. Discover Hue Bridge" >&2
    echo "  2. Connect to Bridge" >&2
    echo "  3. Select Room" >&2
    echo "  4. Sync Current Theme" >&2
    echo "  5. Show Color Probabilities" >&2
    echo "  6. Set Brightness (current: ${BRIGHTNESS}%)" >&2
    echo "  7. Set Sync Mode (current: $MODE)" >&2
    echo "  8. Exit" >&2
    echo >&2
    
    while true; do
        read -rp "Enter choice (1-8): " choice
        if [[ "$choice" =~ ^[1-8]$ ]]; then
            echo "$choice"
            return
        fi
        echo "Invalid choice. Please enter 1-8." >&2
    done
}

# ============================================================================
# Feature Functions
# ============================================================================

discover_bridge() {
    clear_screen
    print_header
    
    echo "🔍 Searching for Hue bridge on your network..."
    echo "   This may take a few seconds..."
    echo
    
    local discovered_ip
    discovered_ip=$(hue_discover)
    
    if [[ -n "$discovered_ip" ]]; then
        if hue_test_connection "$discovered_ip"; then
            BRIDGE_IP="$discovered_ip"
            echo "✓ Bridge found at: $BRIDGE_IP"
            echo "  Connection test: OK"
        else
            echo "⚠ Found bridge at $discovered_ip but cannot connect"
            echo "  Please check your network connection"
        fi
    else
        echo "✗ No bridge found on your network"
        echo
        echo "Troubleshooting:"
        echo "  • Make sure the bridge is powered on"
        echo "  • Check that it's connected to your network"
        echo "  • Ensure you're on the same network as the bridge"
    fi
}

connect_bridge() {
    clear_screen
    print_header
    
    if [[ -z "$BRIDGE_IP" ]]; then
        echo "⚠ Please discover the bridge first or enter IP manually:"
        read -rp "   Bridge IP (or press Enter to cancel): " manual_ip
        
        if [[ -z "$manual_ip" ]]; then
            return
        fi
        
        if ! hue_test_connection "$manual_ip"; then
            echo
            echo "✗ Cannot connect to bridge at $manual_ip"
            return
        fi
        
        BRIDGE_IP="$manual_ip"
    fi
    
    echo "🔗 Connecting to bridge..."
    echo "   Bridge IP: $BRIDGE_IP"
    echo
    echo "⚠ IMPORTANT: Press the link button on your Hue bridge"
    echo "   (the round button on top of the bridge)"
    echo
    read -rp "   Press Enter when ready..."
    echo
    
    local registered_username
    registered_username=$(hue_register "$BRIDGE_IP" 2>&1)
    
    if [[ $? -eq 0 ]] && [[ -n "$registered_username" ]]; then
        USERNAME="$registered_username"
        config_save_credentials "$BRIDGE_IP" "$USERNAME"
        echo "✓ Successfully connected!"
        echo "   Username: ${USERNAME:0:20}..."
        echo "   Credentials saved for future use"
    else
        echo "✗ Registration failed"
        echo "   Error: $registered_username"
        echo
        echo "   Please make sure you pressed the link button"
        echo "   You have 30 seconds after pressing it to complete"
    fi
}

select_room() {
    clear_screen
    print_header
    
    if [[ -z "$USERNAME" ]]; then
        echo "⚠ Please connect to the bridge first"
        return
    fi
    
    echo "📍 Fetching rooms from bridge..."
    echo
    
    local rooms
    rooms=$(hue_get_rooms "$BRIDGE_IP" "$USERNAME")
    
    if [[ "$rooms" == "[]" ]] || [[ -z "$rooms" ]]; then
        echo "✗ No rooms found on your bridge"
        return
    fi
    
    local room_count
    room_count=$(echo "$rooms" | jq '. | length')
    
    echo "Found $room_count room(s):"
    echo
    
    # Display rooms
    local i=1
    while IFS= read -r room; do
        local name light_count
        name=$(echo "$room" | jq -r '.name')
        light_count=$(echo "$room" | jq '.lights | length')
        echo "  $i. $name ($light_count light$([ $light_count -ne 1 ] && echo "s" || echo ""))"
        ((i++))
    done < <(echo "$rooms" | jq -c '.[]')
    
    echo "  0. Cancel"
    echo
    
    while true; do
        read -rp "Select room: " choice
        
        if [[ "$choice" == "0" ]]; then
            return
        fi
        
        if [[ "$choice" =~ ^[0-9]+$ ]] && [[ $choice -ge 1 ]] && [[ $choice -le $room_count ]]; then
            local selected_room
            selected_room=$(echo "$rooms" | jq -c ".[$((choice - 1))]")
            ROOM_ID=$(echo "$selected_room" | jq -r '.id')
            ROOM_NAME=$(echo "$selected_room" | jq -r '.name')
            config_save_room "$ROOM_ID" "$ROOM_NAME"
            config_refresh_room_lights "$ROOM_ID" "$BRIDGE_IP" "$USERNAME" >/dev/null
            echo
            echo "✓ Selected: $ROOM_NAME"
            return
        else
            echo "Invalid choice. Please enter a number between 0 and $room_count."
        fi
    done
}

sync_theme() {
    clear_screen
    print_header
    
    if [[ -z "$USERNAME" ]]; then
        echo "⚠ Please connect to the bridge first"
        return
    fi
    
    if [[ -z "$ROOM_ID" ]]; then
        echo "⚠ Please select a room first"
        return
    fi
    
    local theme
    theme=$(colors_get_current_theme)
    echo "🎨 Current theme: $theme"
    echo
    
    local palette
    palette=$(colors_get_palette)
    
    if [[ -z "$palette" ]]; then
        echo "✗ No colors found for current theme"
        return
    fi
    
    local palette_count
    palette_count=$(echo "$palette" | wc -l)
    echo "Weighted palette: $palette_count colors"
    echo
    
    local variation
    variation=$(config_get_variation)
    local base_brightness
    base_brightness=$(config_get_brightness)
    
    echo "📍 Getting lights in $ROOM_NAME..."
    local lights
    lights=$(config_get_cached_room_lights "$ROOM_ID")
    
    if [[ -z "$lights" ]] || [[ "$lights" == "[]" ]]; then
        lights=$(config_refresh_room_lights "$ROOM_ID" "$BRIDGE_IP" "$USERNAME")
    fi
    
    if [[ "$lights" == "[]" ]] || [[ -z "$lights" ]]; then
        echo "✗ No lights found in selected room"
        return
    fi
    
    local light_count
    light_count=$(echo "$lights" | jq 'length')
    
    if [[ "$light_count" -eq 0 ]]; then
        echo "✗ No lights in room"
        return
    fi
    
    echo "Found $light_count light(s) in $ROOM_NAME"
    echo "   Brightness: ${base_brightness}% (range: $((base_brightness - variation < 0 ? 0 : base_brightness - variation))%-$((base_brightness + variation > 100 ? 100 : base_brightness + variation))%)"
    echo "   Colors will have ±5% variation for variety"
    echo "   Mode: $MODE"
    echo
    
    echo "💡 Syncing theme to room..."
    
    local success_count=0
    
    while IFS= read -r light; do
        local light_id
        light_id=$(echo "$light" | jq -r '.id')
        
        local color_info
        color_info=$(colors_pick_weighted "$palette")
        IFS=':' read -r color_name hex_color <<< "$color_info"
        
        hex_color=$(colors_add_variation "$hex_color" 5)
        
        local xy
        xy=$(colors_hex_to_xy "$hex_color")
        read -r xy_x xy_y <<< "$xy"
        
        xy=$(colors_clamp_gamut "$xy_x" "$xy_y")
        read -r xy_x xy_y <<< "$xy"
        
        local brightness
        brightness=$(colors_get_randomized_brightness "$base_brightness" "$variation")
        
        xy_x=$(LC_NUMERIC=C printf "%.4f" "$xy_x")
        xy_y=$(LC_NUMERIC=C printf "%.4f" "$xy_y")
        
        local action_json
        action_json=$(jq -n \
            --argjson bri "$brightness" \
            --argjson x "$xy_x" \
            --argjson y "$xy_y" \
            '{on: true, bri: $bri, xy: [$x, $y]}')
        
        hue_set_light_state "$light_id" "$action_json" "$BRIDGE_IP" "$USERNAME"
        
        local bri_percent=$(( (brightness * 100) / 254 ))
        echo "  ✓ Light $light_id → $color_name ($hex_color) @ ${bri_percent}%"
        ((success_count++))
    done < <(echo "$lights" | jq -c '.[]')
    
    echo
    echo "✓ Synced $success_count lights with $theme theme!"
}

set_brightness() {
    clear_screen
    print_header
    
    echo "💡 Brightness Settings"
    echo "------------------------------------------------------------"
    echo "Current brightness: ${BRIGHTNESS}%"
    local variation
    variation=$(config_get_variation)
    echo "Variation: ±${variation}%"
    echo
    echo "Each light will get a random brightness between"
    echo "$((BRIGHTNESS - variation < 0 ? 0 : BRIGHTNESS - variation))% and $((BRIGHTNESS + variation > 100 ? 100 : BRIGHTNESS + variation))%"
    echo
    
    while true; do
        read -rp "Enter new brightness (1-100, or press Enter to keep ${BRIGHTNESS}%): " new_brightness
        
        if [[ -z "$new_brightness" ]]; then
            echo "Brightness unchanged."
            return
        fi
        
        if [[ "$new_brightness" =~ ^[0-9]+$ ]] && [[ $new_brightness -ge 1 ]] && [[ $new_brightness -le 100 ]]; then
            BRIGHTNESS="$new_brightness"
            config_save_brightness "$BRIGHTNESS"
            echo "✓ Brightness set to ${BRIGHTNESS}%"
            echo "  Lights will vary between $((BRIGHTNESS - variation < 0 ? 0 : BRIGHTNESS - variation))% and $((BRIGHTNESS + variation > 100 ? 100 : BRIGHTNESS + variation))%"
            return
        else
            echo "Please enter a value between 1 and 100."
        fi
    done
}

set_mode() {
    clear_screen
    print_header
    
    echo "🎯 Sync Mode"
    echo "------------------------------------------------------------"
    echo "Current mode: $MODE"
    echo
    echo "Options:"
    echo "  1. Group (fast)     - All lights same color (1 request)"
    echo "  2. Individual (slow) - Random color per light (N requests)"
    echo
    echo "Group mode is faster but all lights show the same color."
    echo "Individual mode is slower but each light gets a unique color."
    echo
    
    while true; do
        read -rp "Select mode (1-2): " choice
        
        if [[ "$choice" == "1" ]]; then
            MODE="group"
            config_save_mode "$MODE"
            echo "✓ Mode set to: group (fast)"
            return
        elif [[ "$choice" == "2" ]]; then
            MODE="individual"
            config_save_mode "$MODE"
            echo "✓ Mode set to: individual (slow)"
            return
        else
            echo "Invalid choice. Please enter 1 or 2."
        fi
    done
}

show_color_probabilities() {
    clear_screen
    print_header
    
    local theme
    theme=$(colors_get_current_theme)
    echo "🎨 Current theme: $theme"
    echo
    echo "Color probabilities for weighted random selection:"
    echo "------------------------------------------------------------"
    
    local palette
    palette=$(colors_get_palette)
    
    if [[ -z "$palette" ]]; then
        echo "✗ No colors found for current theme"
        return
    fi
    
    local -a names=()
    local -a hexes=()
    local -a weights=()
    
    while IFS=':' read -r name hex weight; do
        local int_weight
        if [[ "$weight" == "0.3" ]]; then
            int_weight=3
        elif [[ "$weight" == "1" ]]; then
            int_weight=10
        elif [[ "$weight" == "3" ]]; then
            int_weight=30
        else
            int_weight=$(printf "%.0f" "${weight//./}0" 2>/dev/null || echo 10)
        fi
        
        names+=("$name")
        hexes+=("$hex")
        weights+=("$int_weight")
    done <<< "$palette"
    
    local total_weight=0
    for w in "${weights[@]}"; do
        total_weight=$((total_weight + w))
    done
    
    for i in "${!names[@]}"; do
        local probability=$(( weights[i] * 1000 / total_weight ))
        local prob_decimal=$(( probability % 10 ))
        probability=$(( probability / 10 ))
        
        local bar_length=$(( probability / 5 ))
        local bar=""
        for ((j=0; j<bar_length; j++)); do
            bar+="█"
        done
        
        local hex="${hexes[i]}"
        local r=$((16#${hex:1:2}))
        local g=$((16#${hex:3:2}))
        local b=$((16#${hex:5:2}))
        
        local bg_rgb="48;2;$r;$g;$b"
        local fg_rgb="38;2;$r;$g;$b"
        
        local contrast=$(( (r*299 + g*587 + b*114) / 1000 ))
        if [[ $contrast -gt 128 ]]; then
            printf "  \033[%sm  \033[0m %-20s %s %2d.%d%% " "$bg_rgb" "${names[i]}" "$hex" "$probability" "$prob_decimal"
        else
            printf "  \033[%sm  \033[0m %-20s %s %2d.%d%% " "$bg_rgb" "${names[i]}" "$hex" "$probability" "$prob_decimal"
        fi
        printf "%-${bar_length}s\n" "$bar"
    done
    
    echo "------------------------------------------------------------"
    echo "Total colors: ${#names[@]}"
    echo "Total weight: $total_weight"
}

# ============================================================================
# Main Loop
# ============================================================================

init_state() {
    # Check dependencies
    if ! config_check_dependencies; then
        exit 1
    fi
    
    # Load existing config
    BRIDGE_IP=$(config_get_bridge_ip)
    USERNAME=$(config_get_username)
    ROOM_ID=$(config_get_room_id)
    ROOM_NAME=$(config_get_room_name)
    BRIGHTNESS=$(config_get_brightness)
    MODE=$(config_get_mode)
}

main() {
    init_state
    
    while true; do
        clear_screen
        print_header
        print_status
        
        choice=$(show_menu)
        
        case "$choice" in
            1)
                discover_bridge
                read -rp $'\nPress Enter to continue...'
                ;;
            2)
                connect_bridge
                read -rp $'\nPress Enter to continue...'
                ;;
            3)
                select_room
                read -rp $'\nPress Enter to continue...'
                ;;
            4)
                sync_theme
                read -rp $'\nPress Enter to continue...'
                ;;
            5)
                show_color_probabilities
                read -rp $'\nPress Enter to continue...'
                ;;
            6)
                set_brightness
                read -rp $'\nPress Enter to continue...'
                ;;
            7)
                set_mode
                read -rp $'\nPress Enter to continue...'
                ;;
            8)
                clear_screen
                echo
                echo "👋 Goodbye!"
                echo
                exit 0
                ;;
        esac
    done
}

# Trap Ctrl+C
trap 'echo -e "\n\n👋 Goodbye!"; exit 0' INT

main "$@"
